# SciForge Sci-Modality Router Service — copy to .env and fill in. NEVER commit real keys.

# OpenAI-compatible expert-translator endpoint (required). This is the local GPU
# service that runs the six real expert models. e.g. http://127.0.0.1:8001/v1
EXPERT_PROVIDER_BASE_URL=http://127.0.0.1:8001/v1
# Usually irrelevant for the local GPU service, kept for wire-format / future auth.
EXPERT_PROVIDER_API_KEY=sk-local
# Robustness lives here (the main agent cannot read these modalities): retry transient failures.
EXPERT_PROVIDER_TIMEOUT_MS=180000   # per-attempt timeout; GPU load + inference can be slow
EXPERT_PROVIDER_MAX_ATTEMPTS=6      # total attempts before giving up
EXPERT_PROVIDER_RETRY_BASE_MS=1500  # exponential backoff base (capped at 15s)

SCIMODALITY_ROUTER_HOST=127.0.0.1
SCIMODALITY_ROUTER_PORT=3898
