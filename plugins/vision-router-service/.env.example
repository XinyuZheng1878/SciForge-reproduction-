# SciForge Vision Router Service — copy to .env and fill in. NEVER commit real keys.

# OpenAI-compatible vision endpoint selected by the Model Router operator.
VISION_PROVIDER_BASE_URL=https://your-vision-provider.example/v1
VISION_PROVIDER_MODEL=replace-with-licensed-vision-model
VISION_PROVIDER_API_KEY=replace-with-vision-provider-key
# Robustness lives here (the main agent has no vision fallback): retry transient failures.
VISION_PROVIDER_TIMEOUT_MS=180000   # per-attempt timeout; vision providers can be slow
VISION_PROVIDER_MAX_ATTEMPTS=6      # total attempts before giving up
VISION_PROVIDER_RETRY_BASE_MS=1500  # exponential backoff base (capped at 15s)

VISION_ROUTER_HOST=127.0.0.1
VISION_ROUTER_PORT=3899
VISION_ROUTER_RUNTIME_TOKEN=replace-with-local-runtime-token
VISION_ROUTER_MAX_BODY_BYTES=41943040
