{
  "name": "sciforge",
  "productName": "SciForge",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Electron workbench for selectable local agent runtimes",
  "main": "./out/main/index.js",
  "type": "module",
  "workspaces": [
    "packages/workers/computer-use",
    "packages/workers/model-router",
    "packages/workers/schedule",
    "packages/workers/search",
    "packages/workers/workflow",
    "packages/workers/workspace-intel",
    "packages/workers/write-assist",
    "packages/workers/paper-radar",
    "packages/workers/sci-modality-router",
    "packages/workers/evidence-dag",
    "packages/workers/runtime-inspector",
    "packages/workers/remote-executor",
    "packages/workers/scientific-plotting",
    "packages/workers/image-generation",
    "packages/workers/multi-agent",
    "packages/workers/ppt-master",
    "packages/workers/canvas",
    "plugins/paper-radar-service"
  ],
  "scripts": {
    "dev": "npm run build:local-runtime && electron-vite dev",
    "build": "npm run build:local-runtime && electron-vite build",
    "build:local-runtime": "node ./scripts/local-runtime-package.cjs build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never",
    "license:package-audit": "node ./scripts/package-release-audit.mjs",
    "dist:mac": "rm -f dist/SciForge-*-mac-* dist/latest-mac.yml && npm run build && npm run dist:mac:x64:dmg && npm run dist:mac:x64:zip && npm run dist:mac:arm64:dmg && npm run dist:mac:arm64:zip && node ./scripts/generate-mac-latest.cjs dist",
    "dist:mac:signed": "rm -f dist/SciForge-*-mac-* dist/latest-mac.yml && MAC_SIGN=1 npm run dist:mac:x64 && MAC_SIGN=1 npm run dist:mac:arm64 && node ./scripts/generate-mac-latest.cjs dist",
    "dist:mac:arm64": "npm run build && npm run dist:mac:arm64:dmg && npm run dist:mac:arm64:zip",
    "dist:mac:x64": "npm run build && npm run dist:mac:x64:dmg && npm run dist:mac:x64:zip",
    "dist:mac:arm64:dmg": "npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never --mac dmg --arm64",
    "dist:mac:x64:dmg": "npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never --mac dmg --x64",
    "dist:mac:arm64:zip": "node ./scripts/zip-mac-app.cjs arm64",
    "dist:mac:x64:zip": "node ./scripts/zip-mac-app.cjs x64",
    "dist:win": "npm run dist -- --win nsis --x64",
    "dist:linux": "npm run dist -- --linux AppImage --x64",
    "release:mac": "bash ./scripts/release-mac.sh",
    "release:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-win.ps1",
    "r2:upload": "node ./scripts/publish-r2.mjs upload",
    "r2:promote": "node ./scripts/publish-r2.mjs promote",
    "postinstall": "node ./scripts/postinstall.cjs",
    "verify:apple": "node ./scripts/verify-apple-signing.cjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "model-router:start": "npm --workspace @sciforge/model-router run start",
    "model-router:test": "npm --workspace @sciforge/model-router run test",
    "model-router:typecheck": "npm --workspace @sciforge/model-router run typecheck",
    "computer-use:start": "npm --workspace @sciforge/computer-use run start",
    "computer-use:test": "npm --workspace @sciforge/computer-use run test",
    "computer-use:typecheck": "npm --workspace @sciforge/computer-use run typecheck",
    "computer-use:smoke:mac": "npm --workspace @sciforge/computer-use run smoke:mac",
    "search:start": "npm --workspace @sciforge/search run start",
    "search:test": "npm --workspace @sciforge/search run test",
    "search:typecheck": "npm --workspace @sciforge/search run typecheck",
    "schedule:start": "npm --workspace @sciforge/schedule run start",
    "schedule:test": "npm --workspace @sciforge/schedule run test",
    "schedule:typecheck": "npm --workspace @sciforge/schedule run typecheck",
    "workflow:start": "npm --workspace @sciforge/workflow run start",
    "workflow:test": "npm --workspace @sciforge/workflow run test",
    "workflow:typecheck": "npm --workspace @sciforge/workflow run typecheck",
    "workspace-intel:start": "npm --workspace @sciforge/workspace-intel run start",
    "workspace-intel:test": "npm --workspace @sciforge/workspace-intel run test",
    "workspace-intel:typecheck": "npm --workspace @sciforge/workspace-intel run typecheck",
    "write-assist:start": "npm --workspace @sciforge/write-assist run start",
    "write-assist:test": "npm --workspace @sciforge/write-assist run test",
    "write-assist:typecheck": "npm --workspace @sciforge/write-assist run typecheck",
    "paper-radar-mcp:start": "npm --workspace @sciforge/paper-radar run start",
    "paper-radar-mcp:test": "npm --workspace @sciforge/paper-radar run test",
    "paper-radar-mcp:typecheck": "npm --workspace @sciforge/paper-radar run typecheck",
    "runtime-inspector:start": "npm --workspace @sciforge/runtime-inspector run start",
    "runtime-inspector:test": "npm --workspace @sciforge/runtime-inspector run test",
    "runtime-inspector:typecheck": "npm --workspace @sciforge/runtime-inspector run typecheck",
    "remote-executor:start": "npm --workspace @sciforge/remote-executor run start",
    "remote-executor:test": "npm --workspace @sciforge/remote-executor run test",
    "remote-executor:typecheck": "npm --workspace @sciforge/remote-executor run typecheck",
    "local-runtime:test": "npm --prefix kun run test",
    "local-runtime:typecheck": "npm --prefix kun run typecheck",
    "evidence-dag:start": "npm --workspace @sciforge/evidence-dag run start",
    "evidence-dag:test": "npm --workspace @sciforge/evidence-dag run test",
    "evidence-dag:samples": "npm --workspace @sciforge/evidence-dag run samples",
    "paper-radar:start": "npm --workspace sciforge-paper-radar-service run start",
    "paper-radar:test": "npm --workspace sciforge-paper-radar-service run test",
    "paper-radar:typecheck": "npm --workspace sciforge-paper-radar-service run typecheck",
    "sci-modality-router:start": "npm --workspace @sciforge/sci-modality-router run start",
    "sci-modality-router:test": "npm --workspace @sciforge/sci-modality-router run test",
    "sci-modality-router:typecheck": "npm --workspace @sciforge/sci-modality-router run typecheck",
    "mac:unquarantine": "bash ./scripts/mac-unquarantine.sh",
    "scientific-plotting:start": "npm --workspace @sciforge/scientific-plotting run start",
    "scientific-plotting:test": "npm --workspace @sciforge/scientific-plotting run test",
    "scientific-plotting:typecheck": "npm --workspace @sciforge/scientific-plotting run typecheck",
    "image-generation:start": "npm --workspace @sciforge/image-generation run start",
    "image-generation:test": "npm --workspace @sciforge/image-generation run test",
    "image-generation:typecheck": "npm --workspace @sciforge/image-generation run typecheck",
    "multi-agent:test": "npm --workspace @sciforge/multi-agent run test",
    "multi-agent:typecheck": "npm --workspace @sciforge/multi-agent run typecheck",
    "ppt-master:start": "npm --workspace @sciforge/ppt-master run start",
    "ppt-master:test": "npm --workspace @sciforge/ppt-master run test",
    "ppt-master:typecheck": "npm --workspace @sciforge/ppt-master run typecheck",
    "canvas:start": "npm --workspace @sciforge/canvas run start",
    "canvas:test": "npm --workspace @sciforge/canvas run test",
    "canvas:typecheck": "npm --workspace @sciforge/canvas run typecheck",
    "smoke:scientific-plotting-style": "node ./scripts/scientific-plotting-style-regression.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@aws-sdk/client-s3": "^3.1049.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tencent-weixin/openclaw-weixin": "2.4.3",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-image": "3.26.0",
    "@tiptap/extension-list": "3.26.0",
    "@tiptap/extension-mathematics": "3.26.0",
    "@tiptap/extension-table": "3.26.0",
    "@tiptap/markdown": "3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/starter-kit": "3.26.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^12.10.0",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "html-to-docx": "^1.8.0",
    "i18next": "^25.4.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "lucide-react": "^0.544.0",
    "node-pty": "^1.1.0",
    "openclaw": "file:vendor/openclaw-shim",
    "pdfjs-dist": "5.4.394",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4",
    "react-markdown": "^10.1.0",
    "rehype-harden": "^1.1.8",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^3.23.0",
    "streamdown": "^2.5.0",
    "unified": "^11.0.5",
    "ws": "^8.20.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.3",
    "@napi-rs/canvas": "^0.1.100",
    "fractional-indexing": "^3.2.0",
    "tldraw": "^4.2.0"
  },
  "overrides": {
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-blockquote": "3.26.0",
    "@tiptap/extension-bold": "3.26.0",
    "@tiptap/extension-bullet-list": "3.26.0",
    "@tiptap/extension-code": "3.26.0",
    "@tiptap/extension-code-block": "3.26.0",
    "@tiptap/extension-document": "3.26.0",
    "@tiptap/extension-dropcursor": "3.26.0",
    "@tiptap/extension-gapcursor": "3.26.0",
    "@tiptap/extension-hard-break": "3.26.0",
