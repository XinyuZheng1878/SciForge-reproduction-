{
  "name": "@sciforge/canvas",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "SciForge Canvas worker MCP server with Cowart-compatible review workflows.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": true,
    "sideEffects": "filesystem",
    "publicContract": true,
    "runtimeAdapter": true,
    "mcpServer": true
  },
  "bin": {
    "sciforge-canvas": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./engine": "./src/sciforge-canvas-engine.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fractional-indexing": "^3.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7"
  }
}
