{
  "name": "@sciforge/paper-radar",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": false,
  "description": "SciForge Paper Radar MCP facade backed by the shared Paper Radar SQLite store.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": false,
    "sideEffects": "filesystem, network",
    "publicContract": true,
    "runtimeAdapter": false,
    "mcpServer": true,
    "packagingStrategy": "ship with packages/workers/paper-radar and the existing sciforge-paper-radar-service plugin dependency; main-process launch config must pass PAPER_RADAR_DB and PAPER_RADAR_PROFILES from the userData paper-radar directory"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "sciforge-paper-radar-mcp": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sciforge-paper-radar-service": "file:../../../plugins/paper-radar-service",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
