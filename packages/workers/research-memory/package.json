{
  "name": "@sciforge/research-memory",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "MCP-first SciForge research memory worker for local artifacts, policy checks, drafts, status pages, and GitHub review handoff.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": true,
    "sideEffects": "filesystem, network",
    "publicContract": true,
    "runtimeAdapter": false,
    "mcpServer": true
  },
  "bin": {
    "sciforge-research-memory": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
