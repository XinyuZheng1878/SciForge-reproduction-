{
  "name": "@sciforge/schedule",
  "version": "0.1.0",
  "license": "LicenseRef-SciForge-Academic-NonCommercial",
  "type": "module",
  "private": false,
  "description": "Shared SciForge schedule worker MCP server and internal HTTP client.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": false,
    "sideEffects": "network",
    "publicContract": true,
    "runtimeAdapter": true,
    "mcpServer": true
  },
  "bin": {
    "sciforge-schedule": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
