{
  "name": "@sciforge/runtime-inspector",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "private": false,
  "description": "Read-only SciForge Git, LSP, and runtime diagnostics MCP worker.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": false,
    "sideEffects": "filesystem, network, process",
    "publicContract": true,
    "runtimeAdapter": false,
    "mcpServer": true
  },
  "bin": {
    "sciforge-runtime-inspector": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./contract": "./src/contract.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
