# Computer-use worker config. Copy to `.env` (gitignored); never commit real keys.
#
# Model calls must go through SciForge Model Router. Configure the router profile
# to point its public alias at a user/operator supplied vision-capable computer-use
# model or remote service. This worker does not ship weights or a raw provider URL.

CUA_MODEL_ROUTER_BASE_URL=http://127.0.0.1:3892/v1
CUA_MODEL_ROUTER_MODEL=sciforge-router
CUA_MODEL_ROUTER_API_KEY=replace-with-model-router-runtime-key
CUA_GROUNDING_DIM=1000

# Loop / safety
CUA_MAX_STEPS=15
# Sliding window: how many recent steps keep their screenshot in the routed prompt.
CUA_IMAGE_WINDOW=2
CUA_SETTLE_S=0.25
CUA_NONPROGRESS_LIMIT=3
# Optional reflection pass through the same Model Router alias. Keep off unless
# the configured router profile is intended to handle the extra image comparison.
CUA_REFLECT=false
CUA_REFLECT_ESCALATE=2
# CUA_REFLECT_MODEL=        # optional separate model for reflection

# Real mouse/keyboard is OFF unless this is true AND the call sets execute+approve.
CUA_ALLOW_EXECUTE=false

# HTTP sidecar port (used by --http and the Kun computer_use tool provider).
CUA_PORT=3900
# Bearer token for POST /computer-use/run and /computer-use/cancel. The GUI
# launcher generates a random token per start; set this only for manual runs.
# CUA_SERVICE_TOKEN=
# CUA_ARTIFACT_DIR=./cua-runs

# Paint a click-through highlight ring + ripple + banner on the real desktop
# during live execution so the user can see where/when the agent acts (Windows;
# no-op elsewhere). Set false to disable.
CUA_SHOW_OVERLAY=true
