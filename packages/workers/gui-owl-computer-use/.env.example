# GUI-Owl computer-use worker — config. Copy to `.env` (gitignored); never commit real keys.
#
# Computer-use is delegated end-to-end to ONE model — GUI-Owl-1.5-32B (Qwen3-VL).
# It reads the screen, plans, grounds (pixel coords) AND decides when to stop, all
# by itself: there is NO planner/grounder split and the main agent does not plan
# the steps. Point it at the GUI-Owl vLLM endpoint (server/serve-gui-owl-32b.sh),
# or in production at the SciForge model router's OpenAI-compatible gateway.

CUA_MODEL_BASE_URL=http://127.0.0.1:4243/v1
CUA_MODEL=gui-owl
CUA_MODEL_API_KEY=EMPTY
CUA_GROUNDING_DIM=1000

# Loop / safety
CUA_MAX_STEPS=15
# Official GUI-Owl sliding window: how many recent steps keep their screenshot in
# the prompt (older steps drop the image; assistant action outputs carry them as
# text). Must be <= the vLLM --limit-mm-per-prompt image cap (serve script: 2).
CUA_IMAGE_WINDOW=2
CUA_SETTLE_S=0.25
CUA_NONPROGRESS_LIMIT=3
# Mobile-Agent-v3 reflector: extra verify-after-each-action pass. The 32B is
# strong enough end-to-end, so default OFF for speed (set true only for the 8B).
CUA_REFLECT=false
CUA_REFLECT_ESCALATE=2
# CUA_REFLECT_MODEL=        # optional separate model for reflection

# Real mouse/keyboard is OFF unless this is true AND the call sets execute+approve.
CUA_ALLOW_EXECUTE=false

# HTTP sidecar port (used by --http and the Kun computer_use tool provider).
CUA_PORT=3900
# Bearer token for POST /computer-use/run and /computer-use/cancel. The GUI
# launcher generates a random token per start; set this only for manual runs.
# CUA_SERVICE_TOKEN=
# CUA_ARTIFACT_DIR=./cua-runs

# Paint a click-through highlight ring + ripple + banner on the real desktop
# during live execution so the user can see where/when the agent acts (Windows;
# no-op elsewhere). Set false to disable.
CUA_SHOW_OVERLAY=true
