{
  "name": "@sciforge/computer-use",
  "version": "0.1.0",
  "license": "LicenseRef-SciForge-Academic-NonCommercial",
  "type": "module",
  "private": false,
  "description": "Shared SciForge Computer Use MCP extension, contracts, lease coordination, and model-visible image helpers.",
  "sciforge": {
    "lifecycleLayer": "workers",
    "skillFacing": false,
    "sideEffects": "host-ui, filesystem, process",
    "publicContract": true,
    "runtimeAdapter": true,
    "mcpServer": true
  },
  "bin": {
    "sciforge-computer-use": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./lease": "./src/lease.ts",
    "./tool-result-image": "./src/tool-result-image.ts",
    "./mcp-server": "./src/mcp-server.ts",
    "./service": "./src/service.ts"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "smoke:mac": "node --import tsx src/smoke-mac.ts"
  },
  "dependencies": {
    "@computer-use/nut-js": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jimp": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
