{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["frontend/*"],
      "@shared/*": ["backend/shared/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["frontend/**/*", "backend/shared/**/*", "backend/preload/index.d.ts"]
}
